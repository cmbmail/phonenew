# ============================================
# 银行电话费用分摊系统 — 环境变量模板
# 复制此文件为 .env 并填入实际值
# ============================================

# --- 数据库 ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=phonecost
DB_USER=phonecost_app
DB_PASSWORD=           # 必填: 数据库应用用户密码

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=        # 必填: Redis密码

# --- JWT ---
JWT_SECRET=            # 必填: JWT签名密钥(建议64字符随机串)

# --- 可选: 管理员默认密码(仅首次启动创建admin用户时使用) ---
DEFAULT_PASSWORD=      # 可选: 不填则使用代码内默认值
